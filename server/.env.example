# server settings
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# docker settings
DOCKER_PYTHON_IMAGE=backend-python
DOCKER_MEMORY_LIMIT=128m
DOCKER_CPU_LIMIT=0.5
DOCKER_PIDS_LIMIT=64
DOCKER_TIMEOUT_MS=10000
MAX_CODE_LENGTH=10000
MAX_OUTPUT_BYTES=51200
TEMP_DIR=./temp

# websocket concurrency cap / max concurrent container count
MAX_CONCURRENT_WS=10

# supabase settings
SUPABASE_URL=
SUPABASE_KEY=